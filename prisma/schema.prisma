generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  phoneNumber String? @unique
  password  String
  name      String?
  role      String   @default("MERCHANT") // MERCHANT, SUPER_ADMIN, CASHIER
  stores    Store[]  @relation("StoreOwner")
  workedAtId Int?
  workedAt   Store?   @relation("StoreCashier", fields: [workedAtId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Store {
  id                      Int       @id @default(autoincrement())
  slug                    String    @unique
  name                    String
  ownerId                 Int
  owner                   User      @relation("StoreOwner", fields: [ownerId], references: [id])
  cashiers                User[]    @relation("StoreCashier")
  orderNotifications      OrderNotification[]
  
  // Settings
  whatsapp                String?
  themeColor              String    @default("#000000")
  whatsappToken           String?
  whatsappPhoneId         String?
  customDomain            String?   // Custom domain for QR codes
  
  // Payment Config
  enableWhatsApp          Boolean   @default(true)
  enableMidtrans          Boolean   @default(false)
  enableXendit            Boolean   @default(false)
  enableManualTransfer    Boolean   @default(false)
  posEnabled              Boolean   @default(false)
  isOpen                  Boolean   @default(true)
  
  // Advanced Payment Settings
  taxPercent              Float     @default(0.0)
  serviceChargePercent    Float     @default(0.0)
  qrisFeePercent          Float     @default(0.7) // Default 0.7% for QRIS
  manualTransferFee       Float     @default(0.0) // Flat fee for Bank Transfer
  feePaidBy               String    @default("CUSTOMER") // CUSTOMER or MERCHANT
  
  // POS Settings
  posGridColumns          Int       @default(4) // 3, 4, 5, 6
  posPaymentMethods       Json?     @default("[]")
  
  paymentGatewaySecret    String?
  paymentGatewayClientKey String?
  bankAccount             Json?     // Stores manual transfer details
  
  // Monetization
  subscriptionPlan        String    @default("FREE") // FREE, PRO
  transactionFeePercent   Float     @default(0.0)
  balance                 Float     @default(0.0)
  waBalance               Float     @default(50000.0)
  waPricePerMessage       Float     @default(350.0)
  waLowCreditAlertSentAt  DateTime?
  
  // Relations
  products                Product[]
  categories              Category[]
  orders                  Order[]
  tables                  Table[]
  withdrawals             Withdrawal[]
  inventory               InventoryItem[]
  waUsageLogs             WaUsageLog[]
  
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

model Withdrawal {
  id                Int      @id @default(autoincrement())
  storeId           Int
  store             Store    @relation(fields: [storeId], references: [id])
  amount            Float
  status            String   @default("PENDING") // PENDING, COMPLETED, REJECTED
  bankName          String
  bankAccountNumber String
  bankAccountName   String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Product {
  id               Int                 @id @default(autoincrement())
  storeId          Int
  store            Store               @relation(fields: [storeId], references: [id])
  name             String
  price            Float
  image            String?
  gallery          String[]            @default([])
  category         String?
  subCategory      String?
  description      String?
  shortDescription String?
  type             String              @default("simple")
  rating           Float               @default(0)
  variations       Json?
  unit             String              @default("pcs")
  stock            Int                 @default(0)
  barcode          String?             // Barcode/SKU for scanning
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  orderItems       OrderItem[]
  ingredients      ProductIngredient[]
}

model ProductIngredient {
  id              Int           @id @default(autoincrement())
  productId       Int
  inventoryItemId Int
  quantity        Float         // How much of the ingredient is used
  quantityUnit    String        @default("pcs")
  baseUnit        String        @default("pcs")
  conversionFactor Float        @default(1)
  product         Product       @relation(fields: [productId], references: [id])
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([productId, inventoryItemId])
}

model Category {
  id            Int       @id @default(autoincrement())
  storeId       Int
  store         Store     @relation(fields: [storeId], references: [id])
  name          String
  slug          String
  image         String?
  subCategories Json?     @default("[]")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([storeId, slug]) // Slug unique per store
}

model Order {
  id            Int         @id @default(autoincrement())
  storeId       Int
  store         Store       @relation(fields: [storeId], references: [id])
  customerPhone String
  tableNumber   String?
  totalAmount   Float
  uniqueCode    Int?        @default(0)
  status        String      @default("PENDING")
  paymentMethod String?
  paymentUrl    String?
  transactionFee Float      @default(0.0) // Fee collected by platform
  taxAmount     Float      @default(0.0)
  serviceCharge Float      @default(0.0)
  discountAmount Float     @default(0.0)
  tipAmount     Float      @default(0.0)
  paymentFee    Float      @default(0.0) // Fee charged to customer if applicable
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]
  notifications OrderNotification[]
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model OrderNotification {
  id        Int      @id @default(autoincrement())
  storeId   Int
  orderId   Int
  source    String
  title     String
  body      String
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id])
  order Order @relation(fields: [orderId], references: [id])

  @@index([storeId, createdAt])
  @@index([storeId, readAt])
  @@index([orderId])
}

model WhatsAppSession {
  id          Int      @id @default(autoincrement())
  phoneNumber String
  storeId     Int?     // Linked to a store if known (via phoneId)
  step        String   @default("START")
  tableNumber String?
  cart        Json?    @default("[]")
  updatedAt   DateTime @updatedAt

  @@unique([phoneNumber, storeId]) // Session per user per store
}

model InventoryItem {
  id          Int      @id @default(autoincrement())
  storeId     Int
  store       Store    @relation(fields: [storeId], references: [id])
  name        String
  barcode     String?  // SKU or Barcode for scanning
  stock       Float    @default(0)
  unit        String   @default("pcs") // pcs, kg, gr, etc.
  minStock    Float    @default(0)     // Alert when below this
  costPrice   Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  productIngredients ProductIngredient[]

  @@unique([storeId, barcode])
}

model ProcessedMessage {
  id        String   @id // Message ID from WhatsApp
  createdAt DateTime @default(now())
}

model WaUsageLog {
  id              Int      @id @default(autoincrement())
  storeId         Int
  store           Store    @relation(fields: [storeId], references: [id])
  type            String
  amount          Float
  description     String
  balanceAfter    Float
  externalRef     String?
  messageId       String?
  messageStatus   String?
  refundedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([storeId, createdAt])
  @@index([externalRef])
  @@index([messageId])
}

model Table {
  id        Int      @id @default(autoincrement())
  storeId   Int
  store     Store    @relation(fields: [storeId], references: [id])
  name      String
  identifier String  // The value in ?table=XYZ
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, identifier])
}

model PlatformSettings {
  key                String   @id @default("default")
  whatsappToken      String?
  whatsappPhoneId    String?
  midtransServerKey  String?
  midtransClientKey  String?
  xenditSecretKey    String?
  bankName           String?
  bankAccountNumber  String?
  bankAccountName    String?
  // New: Subscription Payment Keys (Monthly Rp 299.000)
  subscriptionServerKey String?
  subscriptionClientKey String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
