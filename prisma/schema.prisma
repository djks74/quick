generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  phoneNumber String? @unique
  password  String
  name      String?
  role      String   @default("MERCHANT") // MERCHANT, SUPER_ADMIN, CASHIER
  stores    Store[]  @relation("StoreOwner")
  workedAtId Int?
  workedAt   Store?   @relation("StoreCashier", fields: [workedAtId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Store {
  id                      Int       @id @default(autoincrement())
  slug                    String    @unique
  name                    String
  ownerId                 Int
  owner                   User      @relation("StoreOwner", fields: [ownerId], references: [id])
  cashiers                User[]    @relation("StoreCashier")
  
  // Settings
  whatsapp                String?
  themeColor              String    @default("#000000")
  whatsappToken           String?
  whatsappPhoneId         String?   @unique
  customDomain            String?   // Custom domain for QR codes
  
  // Payment Config
  enableWhatsApp          Boolean   @default(true)
  enableMidtrans          Boolean   @default(false)
  enableXendit            Boolean   @default(false)
  enableManualTransfer    Boolean   @default(false)
  posEnabled              Boolean   @default(false)
  
  // Advanced Payment Settings
  taxPercent              Float     @default(0.0)
  serviceChargePercent    Float     @default(0.0)
  qrisFeePercent          Float     @default(0.7) // Default 0.7% for QRIS
  manualTransferFee       Float     @default(0.0) // Flat fee for Bank Transfer
  feePaidBy               String    @default("CUSTOMER") // CUSTOMER or MERCHANT
  
  // POS Settings
  posGridColumns          Int       @default(4) // 3, 4, 5, 6
  
  paymentGatewaySecret    String?
  paymentGatewayClientKey String?
  bankAccount             Json?     // Stores manual transfer details
  
  // Monetization
  subscriptionPlan        String    @default("FREE") // FREE, PRO
  transactionFeePercent   Float     @default(0.0)
  
  // Relations
  products                Product[]
  categories              Category[]
  orders                  Order[]
  tables                  Table[]
  
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

model Product {
  id               Int         @id @default(autoincrement())
  storeId          Int
  store            Store       @relation(fields: [storeId], references: [id])
  name             String
  price            Float
  image            String?
  gallery          String[]    @default([])
  category         String?
  subCategory      String?
  description      String?
  shortDescription String?
  type             String      @default("simple")
  rating           Float       @default(0)
  variations       Json?
  unit             String      @default("pcs")
  stock            Int         @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  orderItems       OrderItem[]
}

model Category {
  id            Int       @id @default(autoincrement())
  storeId       Int
  store         Store     @relation(fields: [storeId], references: [id])
  name          String
  slug          String
  image         String?
  subCategories Json?     @default("[]")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([storeId, slug]) // Slug unique per store
}

model Order {
  id            Int         @id @default(autoincrement())
  storeId       Int
  store         Store       @relation(fields: [storeId], references: [id])
  customerPhone String
  tableNumber   String?
  totalAmount   Float
  uniqueCode    Int?        @default(0)
  status        String      @default("PENDING")
  paymentMethod String?
  paymentUrl    String?
  transactionFee Float      @default(0.0) // Fee collected by platform
  taxAmount     Float      @default(0.0)
  serviceCharge Float      @default(0.0)
  tipAmount     Float      @default(0.0)
  paymentFee    Float      @default(0.0) // Fee charged to customer if applicable
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model WhatsAppSession {
  id          Int      @id @default(autoincrement())
  phoneNumber String
  storeId     Int?     // Linked to a store if known (via phoneId)
  step        String   @default("START")
  tableNumber String?
  cart        Json?    @default("[]")
  updatedAt   DateTime @updatedAt

  @@unique([phoneNumber, storeId]) // Session per user per store
}

model Table {
  id        Int      @id @default(autoincrement())
  storeId   Int
  store     Store    @relation(fields: [storeId], references: [id])
  name      String
  identifier String  // The value in ?table=XYZ
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, identifier])
}

model PlatformSettings {
  key                String   @id @default("default")
  whatsappToken      String?
  whatsappPhoneId    String?
  midtransServerKey  String?
  midtransClientKey  String?
  xenditSecretKey    String?
  bankName           String?
  bankAccountNumber  String?
  bankAccountName    String?
  // New: Subscription Payment Keys (Monthly Rp 299.000)
  subscriptionServerKey String?
  subscriptionClientKey String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
