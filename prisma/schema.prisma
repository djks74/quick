generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  phoneNumber String?  @unique
  password    String
  name        String?
  role        String   @default("MERCHANT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workedAtId  Int?
  stores      Store[]  @relation("StoreOwner")
  workedAt    Store?   @relation("StoreCashier", fields: [workedAtId], references: [id])
}

model Store {
  id                          Int                 @id @default(autoincrement())
  slug                        String              @unique
  name                        String
  ownerId                     Int
  apiKey                      String?             @unique
  webhookUrl                  String?
  customGeminiKey             String?
  whatsapp                    String?
  themeColor                  String              @default("#000000")
  whatsappToken               String?
  whatsappPhoneId             String?
  customDomain                String?
  enableWhatsApp              Boolean             @default(true)
  enableMidtrans              Boolean             @default(false)
  enableManualTransfer        Boolean             @default(false)
  paymentGatewaySecret        String?
  paymentGatewayClientKey     String?
  bankAccount                 Json?
  subscriptionPlan            String              @default("FREE")
  transactionFeePercent       Float               @default(0.0)
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
  feePaidBy                   String              @default("CUSTOMER")
  manualTransferFee           Float               @default(5000.0)
  posEnabled                  Boolean             @default(false)
  posGridColumns              Int                 @default(4)
  qrisFeePercent              Float               @default(1.0)
  serviceChargePercent        Float               @default(0.0)
  taxPercent                  Float               @default(0.0)
  balance                     Float               @default(0.0)
  isOpen                      Boolean             @default(true)
  isActive                    Boolean             @default(true)
  waBalance                   Float               @default(50000)
  waPricePerMessage           Float               @default(350)
  waLowCreditAlertSentAt      DateTime?
  posPaymentMethods           Json?               @default("[]")
  waCriticalCreditAlertSentAt DateTime?
  biteshipApiKey              String?
  biteshipOriginAreaId        String?
  biteshipOriginLat           Float?
  biteshipOriginLng           Float?
  shippingEnableJne           Boolean             @default(false)
  shippingEnableGosend        Boolean             @default(false)
  shippingJneOnly             Boolean             @default(false)
  shippingEnableStoreCourier  Boolean             @default(false)
  shippingStoreCourierFee     Float               @default(0.0)
  enableTakeawayDelivery      Boolean             @default(true)
  shippingSenderName          String?
  shippingSenderPhone         String?
  shippingSenderAddress       String?
  shippingSenderPostalCode    String?
  categories                  Category[]
  inventory                   InventoryItem[]
  orders                      Order[]
  orderNotifications          OrderNotification[]
  products                    Product[]
  owner                       User                @relation("StoreOwner", fields: [ownerId], references: [id])
  tables                      Table[]
  cashiers                    User[]              @relation("StoreCashier")
  waUsageLogs                 WaUsageLog[]
  withdrawals                 Withdrawal[]
}

model Withdrawal {
  id                Int      @id @default(autoincrement())
  storeId           Int
  amount            Float
  status            String   @default("PENDING")
  bankName          String
  bankAccountNumber String
  bankAccountName   String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  store             Store    @relation(fields: [storeId], references: [id])
}

model Product {
  id               Int                 @id @default(autoincrement())
  storeId          Int
  name             String
  price            Float
  image            String?
  gallery          String[]            @default([])
  category         String?
  subCategory      String?
  description      String?
  shortDescription String?
  type             String              @default("simple")
  rating           Float               @default(0)
  variations       Json?
  unit             String              @default("pcs")
  stock            Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  barcode          String?
  externalId       String?             @unique
  orderItems       OrderItem[]
  store            Store               @relation(fields: [storeId], references: [id])
  ingredients      ProductIngredient[]

  @@unique([storeId, name])
  @@index([externalId])
}

model ProductIngredient {
  id               Int           @id @default(autoincrement())
  productId        Int
  inventoryItemId  Int
  quantity         Float
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  quantityUnit     String        @default("pcs")
  baseUnit         String        @default("pcs")
  conversionFactor Float         @default(1)
  inventoryItem    InventoryItem @relation(fields: [inventoryItemId], references: [id])
  product          Product       @relation(fields: [productId], references: [id])

  @@unique([productId, inventoryItemId])
}

model Category {
  id            Int      @id @default(autoincrement())
  storeId       Int
  name          String
  slug          String
  image         String?
  subCategories Json?    @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  store         Store    @relation(fields: [storeId], references: [id])

  @@unique([storeId, slug])
}

model Order {
  id                 Int                 @id @default(autoincrement())
  storeId            Int
  customerPhone      String
  tableNumber        String?
  totalAmount        Float
  uniqueCode         Int?                @default(0)
  status             String              @default("PENDING")
  paymentMethod      String?
  paymentUrl         String?
  transactionFee     Float               @default(0.0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  paymentFee         Float               @default(0.0)
  serviceCharge      Float               @default(0.0)
  taxAmount          Float               @default(0.0)
  tipAmount          Float               @default(0.0)
  discountAmount     Float               @default(0)
  orderType          String              @default("DINE_IN")
  biteshipOrderId    String?
  shippingProvider   String?
  shippingService    String?
  shippingStatus     String?
  shippingTrackingNo String?
  shippingAddress    String?
  shippingCost       Float               @default(0)
  shippingEta        String?
  notes              String?
  store              Store               @relation(fields: [storeId], references: [id])
  items              OrderItem[]
  notifications      OrderNotification[]
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model OrderNotification {
  id        Int       @id @default(autoincrement())
  storeId   Int
  orderId   Int
  source    String
  title     String
  body      String
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime  @default(now())
  order     Order     @relation(fields: [orderId], references: [id])
  store     Store     @relation(fields: [storeId], references: [id])

  @@index([storeId, createdAt])
  @@index([storeId, readAt])
  @@index([orderId])
}

model WhatsAppSession {
  id          Int      @id @default(autoincrement())
  phoneNumber String
  storeId     Int?
  step        String   @default("START")
  tableNumber String?
  cart        Json?    @default("[]")
  updatedAt   DateTime @updatedAt
  metadata    Json?

  @@unique([phoneNumber, storeId])
}

model InventoryItem {
  id                 Int                 @id @default(autoincrement())
  storeId            Int
  name               String
  barcode            String?
  stock              Float               @default(0)
  unit               String              @default("pcs")
  minStock           Float               @default(0)
  costPrice          Float               @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  store              Store               @relation(fields: [storeId], references: [id])
  productIngredients ProductIngredient[]

  @@unique([storeId, barcode])
}

model ProcessedMessage {
  id        String   @id
  createdAt DateTime @default(now())
}

model WaUsageLog {
  id            Int       @id @default(autoincrement())
  storeId       Int
  type          String
  amount        Float
  description   String
  balanceAfter  Float
  externalRef   String?
  messageId     String?
  messageStatus String?
  refundedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  store         Store     @relation(fields: [storeId], references: [id])

  @@index([storeId, createdAt])
  @@index([externalRef])
  @@index([messageId])
}

model Table {
  id         Int      @id @default(autoincrement())
  storeId    Int
  name       String
  identifier String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  store      Store    @relation(fields: [storeId], references: [id])

  @@unique([storeId, identifier])
}

model TrafficLog {
  id        Int      @id @default(autoincrement())
  storeId   Int?
  path      String
  ip        String?
  userAgent String?
  source    String   @default("WEB")
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([storeId, createdAt])
  @@index([ip])
}

model AnalyticsDaily {
  id           Int      @id @default(autoincrement())
  date         DateTime @unique
  totalOrders  Int      @default(0)
  totalSales   Float    @default(0)
  totalProfit  Float    @default(0)
  totalTraffic Int      @default(0)
  metadata     Json?
  updatedAt    DateTime @updatedAt
}

model PlatformSettings {
  key                   String   @id @default("default")
  whatsappToken         String?
  whatsappPhoneId       String?
  midtransServerKey     String?
  midtransClientKey     String?
  bankName              String?
  bankAccountNumber     String?
  bankAccountName       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  subscriptionServerKey String?
  subscriptionClientKey String?
  biteshipApiKey        String?
  geminiApiKey          String?
}

model WaUserPreference {
  id          Int      @id @default(autoincrement())
  phoneNumber String
  storeId     Int
  language    String   @default("id")
  updatedAt   DateTime @default(now()) @db.Timestamptz(6)

  @@unique([phoneNumber, storeId], map: "WaUserPreference_phone_store_key")
}
